import("std/math") as math

test "math.pi" { math.pi > 3.14 && math.pi < 3.15 }
test "math.e" { math.e > 2.71 && math.e < 2.72 }
test "math.sin" { math.sin(0.0) == 0.0 }
test "math.cos" { math.cos(0.0) == 1.0 }
test "math.asin" { math.asin(0.0) == 0.0 }
test "math.acos" { math.acos(1.0) == 0.0 }
test "math.atan" { math.atan(0.0) == 0.0 }
test "math.atan2" { math.atan2(0.0, 1.0) == 0.0 }
test "math.log" { math.log(math.e) == 1.0 }
test "math.log2" { math.log2(8.0) == 3.0 }
test "math.log10" { math.log10(100.0) == 2.0 }
test "math.sqrt" { math.sqrt(9.0) == 3.0 }
test "math.pow" { math.pow(2.0, 10.0) == 1024.0 }
test "math.abs" { math.abs(-5.0) == 5.0 }
test "math.floor" { math.floor(3.9) == 3 }
test "math.ceil" { math.ceil(3.1) == 4 }
test "math.round" { math.round(3.5) == 4 }
