import("std/witness") as w
import("std/str") as str

let digest  = w.self_digest()
let digest2 = w.self_digest()

test "self_digest is not pending"     { digest != "sha256:pending" }
test "self_digest has sha256: prefix" { str.slice(digest, 0, 7) == "sha256:" }
test "self_digest is stable in run"   { digest == digest2 }
